# =============================================
# Mandarin Coach — Variables d'environnement
# Copier vers .env et remplir les valeurs
# =============================================

# --- proliant — API Go ---
POSTGRES_URL=postgresql://coach_mandarin:CHANGE_ME@localhost:5432/coach_mandarin
REDIS_URL=redis://localhost:6379
AI_HOST=192.168.10.10
AI_SCORER_PORT=8001
AI_WHISPER_PORT=8002
AI_TTS_PORT=8003
OLLAMA_HOST=http://192.168.10.10:11434

# --- Auth / JWT ---
JWT_SECRET=CHANGE_ME_256bit_random_secret
JWT_EXPIRY=24h
REFRESH_EXPIRY=720h
BCRYPT_COST=12

# --- Audio ---
AUDIO_MAX_SIZE_MB=10
AUDIO_MAX_DURATION_S=30
AUDIO_STORAGE_PATH=/data/audio

# --- Traefik (proliant) ---
HOST_DOMAIN=nguyen-huu.fr
ENTRYPOINT=https
RESOLVER=httpresolver

# --- ssh ai ---
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda:0
SCORER_DEVICE=cuda:0
OLLAMA_MODEL=qwen2.5:7b-instruct
SCORER_MODEL_PATH=/models/scorer_best.pt

# --- trainer (3070ti) ---
WS_RELAY_URL=ws://192.168.10.1:8080/ws/training
TRAINING_RUN_ID=
CHECKPOINT_DIR=/checkpoints
CHECKPOINT_NAMING=<model_name>-ph<phase>-ep<epoch>-acc<val_acc>.pt
